{
  "manifest_version": 3,
  "name": "ADHD专注阅读器",
  "version": "0.1.0",
  "description": "面向ADHD用户的中文网页专注阅读器，通过AI辅助和专注工具降低阅读负担",

  "permissions": [
    "storage",
    "activeTab",
    "contextMenus"
  ],

  "host_permissions": [
    "https://openrouter.ai/*"
  ],

  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "src/popup/index.html"
  },

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+R"
      },
      "description": "打开ADHD阅读器"
    }
  }
}
